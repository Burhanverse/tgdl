# --- required ---
TG_API_ID=12345678
TG_API_HASH=your_api_hash_from_my_telegram_org
TG_BOT_TOKEN=123456:ABC-your-bot-token-from-botfather

# --- storage (defaults are fine for most setups) ---
DATA_DIR=./data
LOG_DIR=./logs

# --- gallery-dl pacing (tune down if bunkr still throttles you) ---
GDL_SLEEP_MIN=1.5
GDL_SLEEP_MAX=4.0
GDL_SLEEP_REQUEST=1-3
GDL_LIMIT_RATE=3M
GDL_RETRIES=4
GDL_MAX_RUN_RETRIES=3
GDL_BACKOFF_BASE_S=30
GDL_BACKOFF_MULTIPLIER=2.5

# --- telegram upload pacing ---
TG_UPLOAD_DELAY_MIN=2.0
TG_UPLOAD_DELAY_MAX=4.5
TG_BATCH_SIZE=30
TG_BATCH_COOLDOWN_S=25
TG_UPLOAD_MAX_RETRIES=3
TG_MAX_CONCURRENT_DOWNLOADS=1
TG_MAX_CONCURRENT_UPLOADS=1

LOG_LEVEL=INFO
